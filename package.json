{
  "name": "nutstore-webdav-secret-cli",
  "version": "0.3.0",
  "description": "Terminal UI for managing Nutstore WebDAV app passwords.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "author": "shlroland <shlroland1995@gmail.com>",
  "homepage": "https://github.com/shlroland/nutstore-webdav-secret-cli#readme",
  "bugs": {
    "url": "https://github.com/shlroland/nutstore-webdav-secret-cli/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shlroland/nutstore-webdav-secret-cli.git"
  },
  "keywords": [
    "nutstore",
    "webdav",
    "cli",
    "tui",
    "bun",
    "opentui"
  ],
  "bin": {
    "nutstore-webdav-secret-cli": "./dist/cli.js",
    "nswds": "./dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "dev": "bun run --watch src/cli.tsx",
    "debug": "OTUI_USE_ALTERNATE_SCREEN=false OTUI_USE_CONSOLE=true SHOW_CONSOLE=true bun run --watch src/cli.tsx",
    "typecheck": "bunx tsc --noEmit --pretty false",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "build": "mkdir -p dist && bun run ./scripts/build.ts",
    "build:bin": "mkdir -p dist && BUILD_MODE=compile bun run ./scripts/build.ts",
    "run:dist": "bun ./dist/cli.js",
    "run:bin": "./dist/nswds",
    "release:local": "bun run typecheck && bun run build",
    "release:local:bin": "bun run typecheck && bun run build:bin",
    "pack:check": "bun run build && mkdir -p .cache/npm && npm_config_cache=./.cache/npm npm pack --dry-run",
    "release:npm": "npm publish --access public",
    "prepublishOnly": "bun run typecheck && bun run pack:check"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@effect/atom-solid": "^4.0.0-beta.78",
    "@effect/platform-bun": "4.0.0-beta.78",
    "@effect/platform-node": "4.0.0-beta.78",
    "@opentui/core": "^0.3.2",
    "@opentui/solid": "^0.3.2",
    "add": "^2.0.6",
    "babel-preset-solid": "1.9.12",
    "effect": "^4.0.0-beta.78",
    "solid-js": "1.9.12"
  }
}
